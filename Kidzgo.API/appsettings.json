{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "File": {
      "Path": "logs/kidzgo-.log",
      "ErrorPath": "logs/kidzgo-errors-.log",
      "RetainedFileCountLimit": 14,
      "FileSizeLimitBytes": 20971520,
      "RestrictedToMinimumLevel": "Information",
      "ErrorRestrictedToMinimumLevel": "Error"
    },
    "EventLog": {
      "Enabled": true,
      "Source": "Kidzgo.API",
      "RestrictedToMinimumLevel": "Error"
    },
    "Seq": {
      "ServerUrl": null,
      "RestrictedToMinimumLevel": "Information"
    }
  },
  "AllowedHosts": "*"
}
